import java.util.Random;
import org.graphstream.graph.Graph;
import org.graphstream.graph.Node;
import org.graphstream.graph.implementations.SingleGraph;

public class RandomGraphVisualization {
    private Graph graph;
    private int numNodes;

    public RandomGraphVisualization(int numNodes) {
        this.numNodes = numNodes;
        graph = new SingleGraph("Random Graph");
        generateGraph();
    }

    private void generateGraph() {
    	for (int i = 0; i < numNodes; i++) {
            graph.addNode(String.valueOf(i));
    	}
    	
        Random rand = new Random();
        for (int i = 0; i < numNodes; i++) {
            //graph.addNode(String.valueOf(i));
            for (int j = i+1; j < numNodes; j++) {
                if (rand.nextDouble() < 0.3) {
                	System.out.println("addEdge:" + 
                						String.valueOf(i)+String.valueOf(j) +
                						", " + String.valueOf(i) + 
                						", " + String.valueOf(j));
                    graph.addEdge(String.valueOf(i)+String.valueOf(j), String.valueOf(i), String.valueOf(j));
                }
            }
        }
    }

    public void visualizeGraph() {
        graph.display();
    }

    public static void main(String[] args) {
        RandomGraphVisualization graph = new RandomGraphVisualization(10);
        graph.visualizeGraph();
    }
}
