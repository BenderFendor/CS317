
public class DFS_NonRecursive1 {
	    public static void main(String[] args) {
	        Graph g = new Graph(4);
	        g.addEdge(0, 1);
	        g.addEdge(0, 2);
	        g.addEdge(1, 2);
	        g.addEdge(2, 0);
	        g.addEdge(2, 3);
	        g.addEdge(3, 3);

	        g.dfs();

	        for (int i = 0; i < 4; i++) {
	            System.out.println("Vertex " + i + " visited order: " + g.visitingOrder[i]);
	        }
	    }
	}
