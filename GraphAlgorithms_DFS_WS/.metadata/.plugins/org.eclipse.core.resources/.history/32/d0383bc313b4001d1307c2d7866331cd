import java.util.Random;
import org.graphstream.graph.Graph;
import org.graphstream.graph.Node;
import org.graphstream.graph.implementations.SingleGraph;

import java.io.File;
import java.io.FileWriter;
import java.io.IOException;

//https://graphstream-project.org/doc/Tutorials/Getting-Started/

public class RandomGraphVisualization {
    private Graph graph;
    private int numNodes;
    private int[][] adjMatrix;		//Jia

    public RandomGraphVisualization(int numNodes) {
        this.numNodes = numNodes;
        graph = new SingleGraph("Random Graph");
        generateGraph();
    }

    /**
     * generateGraph(): generate a random graph with numNodes nodes.
     */
    private void generateGraph() {
    	adjMatrix = new int[numNodes][numNodes];	//Jia
    	
    	for (int i = 0; i < numNodes; i++) {
            graph.addNode(String.valueOf(i));
    	}
    	
        Random rand = new Random();
        for (int i = 0; i < numNodes; i++) {
            //graph.addNode(String.valueOf(i));
            for (int j = i+1; j < numNodes; j++) {
                if (rand.nextDouble() < 0.3) {
                	System.out.println("addEdge:" + 
                						String.valueOf(i)+String.valueOf(j) +
                						", " + String.valueOf(i) + 
                						", " + String.valueOf(j));
                    graph.addEdge(String.valueOf(i)+String.valueOf(j), String.valueOf(i), String.valueOf(j));
                    
                    adjMatrix[i][j] = 1;
                }
            }
        }
    }

    /**
     * writeAdjMatrixToFile(): write the generated graph to graph.txt
     * @param fileName
     */
    public void writeAdjMatrixToFile(String fileName) {	//Jia
        try {
            FileWriter writer = new FileWriter(fileName);
            for (int i = 0; i < numNodes; i++) {
                for (int j = i+1; j < numNodes; j++) {
                    if (adjMatrix[i][j] == 1) {
                    	System.out.println(i + ", " + j);
                        writer.write(i + ", " + j + "\n");
                    }
                }
            }
            writer.close();
        } catch (IOException e) {
            e.printStackTrace();
        }
    }//end writeAdjMatrixToFile

            
    public void visualizeGraph() {
        graph.display();
    }

    public static void main(String[] args) {
    	System.setProperty("org.graphstream.ui", "swing");
    	
        RandomGraphVisualization graph = new RandomGraphVisualization(10);
        graph.visualizeGraph();
        
        graph.printAdjMatrix();	//Jia
        graph.writeAdjMatrixToFile("graph.txt");	//Jia
    }
}
